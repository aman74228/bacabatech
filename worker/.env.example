# Bacaba worker environment variables.

# Shared secret — must match WORKER_SECRET in the Next.js app. Used to
# authenticate incoming jobs and outgoing callbacks.
WORKER_SECRET=<a-long-random-string>

# Groq API key for Whisper transcription — https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key>

# Optional: override the Whisper model (default: whisper-large-v3-turbo)
# GROQ_MODEL=whisper-large-v3

# --- YouTube / bot detection ------------------------------------------------
# YouTube (and others) block datacenter IPs with "Sign in to confirm you're not
# a bot". Supply cookies from a logged-in browser to bypass this. Export
# cookies.txt (Netscape format) and provide it as base64:
#   base64 -w0 cookies.txt   (Linux)   |   base64 -i cookies.txt   (macOS)
# YTDLP_COOKIES_B64=<base64-of-cookies.txt>
# ...or paste the raw cookies.txt contents:
# YTDLP_COOKIES=

# Optional extra yt-dlp levers (used without cookies, less reliable):
# YTDLP_EXTRACTOR_ARGS=youtube:player_client=android
# YTDLP_USER_AGENT=Mozilla/5.0 ...

# Port the worker listens on (Railway sets PORT automatically).
PORT=8080
