# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and should never be committed.
#
# Only the two *_SECRET / service-role values are sensitive; the publishable
# key, anon key and URL below are public by design (they ship to the browser).
# Real secret values belong in .env.local and your host's env settings — never
# committed here.

# ---------------------------------------------------------------------------
# Clerk (authentication) — https://dashboard.clerk.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YW1hemVkLXJhY2Nvb24tOTUuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Where Clerk should send users for auth and after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---------------------------------------------------------------------------
# Supabase (database) — https://app.supabase.com -> Project Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://kppgmublfefietbzcrwm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtwcGdtdWJsZmVmaWV0YnpjcndtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzNDYzNDAsImV4cCI6MjA5NjkyMjM0MH0.PSM0w8lD_8L-faxSp6KYvJ-ENFikpG6VNoB9sCZa9U8
# Server-only. Bypasses RLS — never expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ---------------------------------------------------------------------------
# Groq (Whisper transcription) — https://console.groq.com/keys
# Used by the worker, but keep a copy here for reference.
# ---------------------------------------------------------------------------
GROQ_API_KEY=<your-groq-api-key>

# ---------------------------------------------------------------------------
# Inngest (background jobs) — https://app.inngest.com
# ---------------------------------------------------------------------------
INNGEST_EVENT_KEY=<your-inngest-event-key>
INNGEST_SIGNING_KEY=<your-inngest-signing-key>

# ---------------------------------------------------------------------------
# Transcription worker (Railway) — see worker/README.md
# ---------------------------------------------------------------------------
WORKER_URL=https://your-worker.up.railway.app
WORKER_SECRET=<a-long-random-string-shared-with-the-worker>

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
